generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model page_categories {
  id             String           @id
  name           String
  color          String           @default("#6b7280")
  created_at     DateTime         @default(now())
  facebook_pages facebook_pages[]
}

model facebook_pages {
  id                          String              @id
  facebook_account_id         String?
  page_id                     String              @unique
  page_name                   String
  is_active                   Boolean             @default(true)
  created_at                  DateTime            @default(now())
  daily_post_limit            Int                 @default(3)
  page_access_token_encrypted String
  token_status                TokenStatus         @default(active)
  updated_at                  DateTime
  category_id                 String?
  facebook_accounts           facebook_accounts?  @relation(fields: [facebook_account_id], references: [id], onDelete: SetNull)
  page_categories             page_categories?    @relation(fields: [category_id], references: [id], onDelete: SetNull)
  page_media_usage            page_media_usage[]
  post_jobs                   post_jobs[]
  auto_posting_rules          auto_posting_rules?

  @@index([facebook_account_id])
  @@index([category_id])
}

model facebook_accounts {
  id                          String           @id
  facebook_user_id            String           @unique
  facebook_user_name          String
  user_access_token_encrypted String
  token_status                TokenStatus      @default(active)
  connected_at                DateTime         @default(now())
  updated_at                  DateTime
  facebook_pages              facebook_pages[]
}

model media_assets {
  id               String             @id
  file_url         String
  storage_key      String             @unique
  file_name        String
  mime_type        String
  width            Int?
  height           Int?
  size_bytes       Int
  tags             String[]
  status           MediaStatus        @default(available)
  expires_at       DateTime
  created_at       DateTime           @default(now())
  page_media_usage page_media_usage[]
  post_job_media   post_job_media[]

  @@index([status])
  @@index([status, expires_at])
}

model page_media_usage {
  id               String         @id
  facebook_page_id String
  media_asset_id   String
  post_job_id      String?
  used_at          DateTime       @default(now())
  facebook_pages   facebook_pages @relation(fields: [facebook_page_id], references: [id], onDelete: Cascade)
  media_assets     media_assets   @relation(fields: [media_asset_id], references: [id], onDelete: Cascade)
  post_jobs        post_jobs?     @relation(fields: [post_job_id], references: [id])

  @@unique([facebook_page_id, media_asset_id])
  @@index([facebook_page_id])
  @@index([media_asset_id])
  @@index([post_job_id])
}

model post_jobs {
  id               String             @id
  page_id          String
  caption          String?
  scheduled_at     DateTime           @db.Timestamptz(3)
  status           PostJobStatus      @default(pending)
  error_message    String?
  fb_post_id       String?
  posted_at        DateTime?          @db.Timestamptz(3)
  created_at       DateTime           @default(now())
  page_media_usage page_media_usage[]
  post_job_media   post_job_media[]
  facebook_pages   facebook_pages     @relation(fields: [page_id], references: [id], onDelete: Cascade)

  @@index([page_id])
  @@index([page_id, status])
  @@index([status, scheduled_at])
}

model post_job_media {
  id             String       @id
  post_job_id    String
  media_asset_id String
  position       Int          @default(0)
  post_jobs      post_jobs    @relation(fields: [post_job_id], references: [id], onDelete: Cascade)
  media_assets   media_assets @relation(fields: [media_asset_id], references: [id])

  @@unique([post_job_id, position])
  @@index([post_job_id])
}

model settings {
  id    String @id
  key   String @unique
  value Json
}

model users {
  id            String   @id
  email         String   @unique
  password_hash String
  role          UserRole @default(admin)
  created_at    DateTime @default(now())
}

enum MediaStatus {
  available
  used
  expired
  deleted
}

enum PostJobStatus {
  pending
  processing
  posted
  failed
  skipped
}

enum TokenStatus {
  active
  expired
  error
}

enum UserRole {
  admin
  editor
}

model caption_sheets {
  id                 String               @id
  name               String
  captions           String[]
  created_at         DateTime             @default(now())
  updated_at         DateTime
  auto_posting_rules auto_posting_rules[]
}

model auto_posting_rules {
  id                String          @id
  page_id           String          @unique
  is_active         Boolean         @default(true)
  schedule_type     String          @default("daily")
  posts_count       Int             @default(1)
  start_hour        Int             @default(8)
  end_hour          Int             @default(22)
  tag_filter        String[]
  captions          String[]
  caption_sheet_id  String?
  created_at        DateTime        @default(now())
  updated_at        DateTime
  facebook_pages    facebook_pages  @relation(fields: [page_id], references: [id], onDelete: Cascade)
  caption_sheets    caption_sheets? @relation(fields: [caption_sheet_id], references: [id], onDelete: SetNull)
}
